# ─────────────────────────────────────────────────────────────
# Droptix environment
# ─────────────────────────────────────────────────────────────
# Copy to `.env.local` for dev. Production values live on the
# CyberPanel box and are injected into the Node.js app at runtime.
#
# Almost every third-party key lives in the `integrations` table
# (encrypted). The two env secrets below are the irreducible minimum.

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=local                             # local | staging | production

# ── Database ─────────────────────────────────────────────────
# Production: CyberPanel MariaDB on 127.0.0.1:3306, new `droptix_new`
# database reusing the old script's DB server (not its schema).
# Local dev: `docker compose up -d` spins up MariaDB on 3306.
DATABASE_URL=mysql://droptix:droptix@127.0.0.1:3306/droptix_new

# ── Redis (BullMQ + rate limits) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (magic-link only; no passwords) ─────────────────────
AUTH_SECRET=                              # `openssl rand -base64 32`
AUTH_URL=http://localhost:3000

# ── Integrations key vault ───────────────────────────────────
# Used to encrypt/decrypt rows in the `integrations` table
# (Stripe, Postmark, R2, hCaptcha keys, etc). DO NOT rotate
# without re-encrypting the table. 32-byte base64 string.
INTEGRATIONS_ENCRYPTION_KEY=              # `openssl rand -base64 32`

# ── Logging / observability ──────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── Image storage ────────────────────────────────────────────
# Local-disk upload root. MUST be set to an absolute path OUTSIDE
# .next/standalone, otherwise every `pnpm build` rebuilds the
# standalone tree and silently deletes every uploaded image. On the
# CyberPanel box: /home/droptix.co.uk/apps/droptix/uploads
STORAGE_PATH=/absolute/path/to/uploads

# ── Cloudflare (image CDN) ───────────────────────────────────
# Non-secret — public CDN hostname the browser hits.
NEXT_PUBLIC_CDN_URL=https://cdn.droptix.co.uk

# ── Feature flags (dev convenience; prod uses DB-backed flags) ─
NEXT_PUBLIC_ENABLE_RESALE=false
NEXT_PUBLIC_ENABLE_WALLET_PASSES=true
